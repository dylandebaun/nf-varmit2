/*
 * =============================================================================
 *  NF-varmit  –  nextflow.config
 *  Iterative reference-based mapping and consensus calling for WGS data
 * =============================================================================
 */

params {

    // ── Input / output ────────────────────────────────────────────────────────
    indivs_file  = "/path/to/indivs.list"       // one individual ID per line
    chromos_file = "/path/to/chromos.list"       // one chromosome/scaffold name per line
    ref_file     = "/path/to/reference.fa"       // starting reference FASTA

    // ── Read files ────────────────────────────────────────────────────────────
    // Expected filenames: <indiv><reads_suffix1> and <indiv><reads_suffix2>
    readsdir      = "/path/to/reads/"
    reads_suffix1 = "_R1.fastq.gz"
    reads_suffix2 = "_R2.fastq.gz"

    outputdir = "/path/to/results"

    // ── Sex chromosome definition ─────────────────────────────────────────────
    sex_chromos             = ['Z_RagTag']  // list of sex chromosome names in the reference
    auto_chromos_min_length = 10000000      // scaffolds shorter than this excluded from autosome depth stats

    // ── Depth threshold multipliers (applied to mean depth per individual) ────
    // min_cov = max(5, floor(mean * min_depth_multiplier))
    // max_cov = ceil(mean * max_depth_multiplier)
    min_depth_multiplier = 0.5
    max_depth_multiplier = 2.0

    // ── Iterative mapping settings ────────────────────────────────────────────
    n_rounds    = 4    // total rounds of mapping + consensus (must be >= 1)
    start_round = 1    // resume from an existing round (needs prior round outputs in outputdir)

    // ── Analysis toggles ──────────────────────────────────────────────────────
    calc_coverage     = true   // write per-individual coverage summary TSVs and plots
    indiv_var_call    = true   // call variants with freebayes
    call_consensus    = true   // generate consensus FASTA sequences
    calc_missing_data = true   // report missing-data stats on the final consensus

    // ── Variant calling & filtering ───────────────────────────────────────────
    // Applied by freebayes + vcffilter in every round.
    qual_min = 20      // minimum QUAL score
    min_ab   = 0.2     // minimum allele balance to retain a het variant
    max_ab   = 0.8     // maximum allele balance (above this = treated as hom-alt)
    // Indel handling (final round only):
    //   false = retain indels (preserves coordinate system; recommended for alignment)
    //   true  = remove indels (shifts coordinates; individuals not re-alignable)
    filt_indels = false

    // ── Consensus masking ─────────────────────────────────────────────────────
    mask_hets = false   // mask heterozygous sites (AF < 1 & AB < max_ab) → N
    mask_cov  = true    // mask sites outside per-individual depth thresholds → N

    // ── Coverage plot layout ──────────────────────────────────────────────────
    // Number of individuals per panel row in the depth violin plot.
    // Keep rows roughly equal to avoid a sparse last row.
    plots_per_row = 1
}

// ── Cluster profiles ──────────────────────────────────────────────────────────
profiles {

    mendel {
        // AMNH Mendel (Slurm) cluster
        includeConfig 'config/mendel.config'
    }

    curta {
        // Freie Universität Berlin cluster
        includeConfig 'config/curta.config'
    }
}
